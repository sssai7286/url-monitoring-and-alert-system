PORT=5000
MONGO_URI=mongodb://localhost:27017/urlmonitor
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Email config (use Gmail or any SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Alert cooldown in minutes (prevents duplicate alerts)
ALERT_COOLDOWN_MINUTES=10
